<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <Extern href="vsshlids.h"/>
  <Commands package="guidOpenInCursorPkg">

    <!-- ========== Menus: "Open in AI" submenus in each context ========== -->
    <Menus>
      <Menu guid="guidOpenInAICmdSet" id="OpenInAIEditorMenu" priority="0x0600" type="Menu">
        <Parent guid="guidOpenInAICmdSet" id="AnchorEditorGroup"/>
        <Strings>
          <ButtonText>Open in AI</ButtonText>
        </Strings>
      </Menu>
      <Menu guid="guidOpenInAICmdSet" id="OpenInAIItemMenu" priority="0x0600" type="Menu">
        <Parent guid="guidOpenInAICmdSet" id="AnchorItemGroup"/>
        <Strings>
          <ButtonText>Open in AI</ButtonText>
        </Strings>
      </Menu>
      <Menu guid="guidOpenInAICmdSet" id="OpenInAIFolderMenu" priority="0x0600" type="Menu">
        <Parent guid="guidOpenInAICmdSet" id="AnchorFolderGroup"/>
        <Strings>
          <ButtonText>Open in AI</ButtonText>
        </Strings>
      </Menu>
      <Menu guid="guidOpenInAICmdSet" id="OpenInAIProjectMenu" priority="0x0600" type="Menu">
        <Parent guid="guidOpenInAICmdSet" id="AnchorProjectGroup"/>
        <Strings>
          <ButtonText>Open in AI</ButtonText>
        </Strings>
      </Menu>
      <Menu guid="guidOpenInAICmdSet" id="OpenInAISolutionMenu" priority="0x0600" type="Menu">
        <Parent guid="guidOpenInAICmdSet" id="AnchorSolutionGroup"/>
        <Strings>
          <ButtonText>Open in AI</ButtonText>
        </Strings>
      </Menu>
    </Menus>

    <!-- ========== Groups ========== -->
    <Groups>
      <!-- Anchor groups: place the "Open in AI" submenu into each VS context menu -->
      <Group guid="guidOpenInAICmdSet" id="AnchorEditorGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_CODEWIN"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="AnchorItemGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_ITEMNODE"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="AnchorFolderGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_FOLDERNODE"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="AnchorProjectGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_PROJNODE"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="AnchorSolutionGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_SOLNNODE"/>
      </Group>

      <!-- Submenu groups: hold the Cursor / Claude / Copy Position buttons inside each "Open in AI" menu -->
      <Group guid="guidOpenInAICmdSet" id="SubmenuEditorGroup" priority="0x0100">
        <Parent guid="guidOpenInAICmdSet" id="OpenInAIEditorMenu"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="SubmenuItemGroup" priority="0x0100">
        <Parent guid="guidOpenInAICmdSet" id="OpenInAIItemMenu"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="SubmenuFolderGroup" priority="0x0100">
        <Parent guid="guidOpenInAICmdSet" id="OpenInAIFolderMenu"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="SubmenuProjectGroup" priority="0x0100">
        <Parent guid="guidOpenInAICmdSet" id="OpenInAIProjectMenu"/>
      </Group>
      <Group guid="guidOpenInAICmdSet" id="SubmenuSolutionGroup" priority="0x0100">
        <Parent guid="guidOpenInAICmdSet" id="OpenInAISolutionMenu"/>
      </Group>
    </Groups>

    <!-- ========== Buttons ========== -->
    <Buttons>
      <!-- ===== Cursor buttons (inside "Open in AI" submenus) ===== -->
      <Button guid="guidOpenInCursorCmdSet" id="OpenInCursorId" priority="0x0100" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuEditorGroup"/>
        <Icon guid="guidCursorIcon" id="cursorIcon" />
        <Strings>
          <ButtonText>Open in Cursor</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInCursorCmdSet" id="OpenInCursorFileId" priority="0x0100" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuItemGroup"/>
        <Icon guid="guidCursorIcon" id="cursorIcon" />
        <Strings>
          <ButtonText>Open in Cursor</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInCursorCmdSet" id="OpenInCursorFolderId" priority="0x0100" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuFolderGroup"/>
        <Icon guid="guidCursorIcon" id="cursorIcon" />
        <Strings>
          <ButtonText>Open in Cursor</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInCursorCmdSet" id="OpenInCursorProjectId" priority="0x0100" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuProjectGroup"/>
        <Icon guid="guidCursorIcon" id="cursorIcon" />
        <Strings>
          <ButtonText>Open in Cursor</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInCursorCmdSet" id="OpenInCursorSolutionId" priority="0x0100" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuSolutionGroup"/>
        <Icon guid="guidCursorIcon" id="cursorIcon" />
        <Strings>
          <ButtonText>Open in Cursor</ButtonText>
        </Strings>
      </Button>

      <!-- ===== Claude buttons (inside "Open in AI" submenus) ===== -->
      <Button guid="guidOpenInClaudeCmdSet" id="OpenInClaudeId" priority="0x0200" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuEditorGroup"/>
        <Icon guid="guidClaudeIcon" id="claudeIcon" />
        <Strings>
          <ButtonText>Open in Claude</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInClaudeCmdSet" id="OpenInClaudeFileId" priority="0x0200" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuItemGroup"/>
        <Icon guid="guidClaudeIcon" id="claudeIcon" />
        <Strings>
          <ButtonText>Open in Claude</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInClaudeCmdSet" id="OpenInClaudeFolderId" priority="0x0200" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuFolderGroup"/>
        <Icon guid="guidClaudeIcon" id="claudeIcon" />
        <Strings>
          <ButtonText>Open in Claude</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInClaudeCmdSet" id="OpenInClaudeProjectId" priority="0x0200" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuProjectGroup"/>
        <Icon guid="guidClaudeIcon" id="claudeIcon" />
        <Strings>
          <ButtonText>Open in Claude</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInClaudeCmdSet" id="OpenInClaudeSolutionId" priority="0x0200" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuSolutionGroup"/>
        <Icon guid="guidClaudeIcon" id="claudeIcon" />
        <Strings>
          <ButtonText>Open in Claude</ButtonText>
        </Strings>
      </Button>

      <!-- ===== Copy Position buttons (inside "Open in AI" submenus) ===== -->
      <Button guid="guidOpenInAICmdSet" id="CopyPositionEditorId" priority="0x0300" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuEditorGroup"/>
        <Strings>
          <ButtonText>Copy Position</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInAICmdSet" id="CopyPositionFileId" priority="0x0300" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuItemGroup"/>
        <Strings>
          <ButtonText>Copy Position</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInAICmdSet" id="CopyPositionFolderId" priority="0x0300" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuFolderGroup"/>
        <Strings>
          <ButtonText>Copy Position</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInAICmdSet" id="CopyPositionProjectId" priority="0x0300" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuProjectGroup"/>
        <Strings>
          <ButtonText>Copy Position</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidOpenInAICmdSet" id="CopyPositionSolutionId" priority="0x0300" type="Button">
        <Parent guid="guidOpenInAICmdSet" id="SubmenuSolutionGroup"/>
        <Strings>
          <ButtonText>Copy Position</ButtonText>
        </Strings>
      </Button>
    </Buttons>

    <Bitmaps>
      <Bitmap guid="guidCursorIcon" href="icons\context-menu-icon.png" usedList="cursorIcon"/>
      <Bitmap guid="guidClaudeIcon" href="icons\claude-icon.png" usedList="claudeIcon"/>
    </Bitmaps>
  </Commands>

  <Symbols>
    <!-- Package GUID -->
    <GuidSymbol name="guidOpenInCursorPkg" value="{a7fd7efd-fb26-4ae2-b888-221254ed76c4}"/>

    <!-- "Open in AI" command set: menus, anchor/submenu groups, Copy Position buttons -->
    <GuidSymbol name="guidOpenInAICmdSet" value="{710adf41-d261-4cc7-8381-281128ec0ff9}">
      <!-- Anchor groups (in VS context menus) -->
      <IDSymbol name="AnchorEditorGroup" value="0x1010"/>
      <IDSymbol name="AnchorItemGroup" value="0x1011"/>
      <IDSymbol name="AnchorFolderGroup" value="0x1012"/>
      <IDSymbol name="AnchorProjectGroup" value="0x1013"/>
      <IDSymbol name="AnchorSolutionGroup" value="0x1014"/>
      <!-- Submenus -->
      <IDSymbol name="OpenInAIEditorMenu" value="0x1100"/>
      <IDSymbol name="OpenInAIItemMenu" value="0x1101"/>
      <IDSymbol name="OpenInAIFolderMenu" value="0x1102"/>
      <IDSymbol name="OpenInAIProjectMenu" value="0x1103"/>
      <IDSymbol name="OpenInAISolutionMenu" value="0x1104"/>
      <!-- Groups inside submenus -->
      <IDSymbol name="SubmenuEditorGroup" value="0x1200"/>
      <IDSymbol name="SubmenuItemGroup" value="0x1201"/>
      <IDSymbol name="SubmenuFolderGroup" value="0x1202"/>
      <IDSymbol name="SubmenuProjectGroup" value="0x1203"/>
      <IDSymbol name="SubmenuSolutionGroup" value="0x1204"/>
      <!-- Copy Position buttons -->
      <IDSymbol name="CopyPositionEditorId" value="0x0300"/>
      <IDSymbol name="CopyPositionFileId" value="0x0301"/>
      <IDSymbol name="CopyPositionFolderId" value="0x0302"/>
      <IDSymbol name="CopyPositionProjectId" value="0x0303"/>
      <IDSymbol name="CopyPositionSolutionId" value="0x0304"/>
    </GuidSymbol>

    <!-- Cursor command set -->
    <GuidSymbol name="guidOpenInCursorCmdSet" value="{78663741-69ae-455a-a6a5-13487a765188}">
      <IDSymbol name="OpenInCursorId" value="0x0100"/>
      <IDSymbol name="OpenInCursorFileId" value="0x0101"/>
      <IDSymbol name="OpenInCursorFolderId" value="0x0102"/>
      <IDSymbol name="OpenInCursorProjectId" value="0x0103"/>
      <IDSymbol name="OpenInCursorSolutionId" value="0x0104"/>
    </GuidSymbol>

    <!-- Claude command set -->
    <GuidSymbol name="guidOpenInClaudeCmdSet" value="{9a6046a9-547d-4bdd-ac2c-68f41e75f776}">
      <IDSymbol name="OpenInClaudeId" value="0x0200"/>
      <IDSymbol name="OpenInClaudeFileId" value="0x0201"/>
      <IDSymbol name="OpenInClaudeFolderId" value="0x0202"/>
      <IDSymbol name="OpenInClaudeProjectId" value="0x0203"/>
      <IDSymbol name="OpenInClaudeSolutionId" value="0x0204"/>
